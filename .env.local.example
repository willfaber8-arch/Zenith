# ════════════════════════════════════════════════════════════════
# Zenith OS — Environment Variables Template
# Phase 2 · Step 2.2 — Cloud Synchronization Pipeline
#
# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored and never committed.
#
# Where to find these values:
#   Supabase Dashboard → Your Project → Settings → API
# ════════════════════════════════════════════════════════════════

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase project public anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ════════════════════════════════════════════════════════════════
# AI features — OPTIONAL server-side fallback key
#
# Users can supply their OWN key in-app (Settings → AI Provider) — that
# key is stored only in their browser and billed to their own account.
# The variable below is only a fallback used when no user key is present
# (e.g. your own local dev). SERVER-SIDE ONLY — never prefix NEXT_PUBLIC_.
#
# Accepts either provider; the app auto-detects from the key prefix:
#   • Anthropic Claude  →  sk-ant-...   (https://console.anthropic.com)
#   • Google Gemini     →  AIza...      (https://aistudio.google.com/app/apikey)
# ════════════════════════════════════════════════════════════════

# Fallback API key (sk-ant-... for Claude, or AIza... for Gemini)
LLM_API_KEY=

# Optional: override the Anthropic model (used when key is an sk-ant- key)
# Available: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
LLM_MODEL=claude-haiku-4-5-20251001

# Optional: override the Gemini model (used when key is an AIza key)
GEMINI_MODEL=gemini-2.0-flash
