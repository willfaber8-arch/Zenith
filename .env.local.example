# ════════════════════════════════════════════════════════════════
# Zenith OS — Environment Variables Template
# Phase 2 · Step 2.2 — Cloud Synchronization Pipeline
#
# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored and never committed.
#
# Where to find these values:
#   Supabase Dashboard → Your Project → Settings → API
# ════════════════════════════════════════════════════════════════

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase project public anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ════════════════════════════════════════════════════════════════
# Phase 3 · Step 3.5 — AI Lecture Summarizer & Flashcard Generator
#
# Required: Anthropic API key — get one at https://console.anthropic.com
# This is SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# ════════════════════════════════════════════════════════════════

# Your Anthropic API key (sk-ant-...)
LLM_API_KEY=

# Optional: override the default model (claude-haiku-4-5-20251001 is fast + affordable)
# Available: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
LLM_MODEL=claude-haiku-4-5-20251001
